rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "ruknuddin.hamza@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'status', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 255 &&
             data.url is string && data.url.matches("^https://.*") &&
             data.status in ['processing', 'ready', 'error'] &&
             data.userId == request.auth.uid;
    }

    match /videos/{videoId} {
      // Allow reading if the user is the owner or an admin
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidVideo(request.resource.data);
                    
      allow update: if isDocOwner() && 
                    request.resource.data.userId == resource.data.userId &&
                    isValidVideo(request.resource.data);
                    
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
